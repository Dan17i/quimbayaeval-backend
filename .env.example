# JWT Configuration
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_SECRET_KEY_AT_LEAST_256_BITS
JWT_EXPIRATION=86400000

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/quimbayaeval
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# CORS Configuration (Frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Application Configuration
SPRING_PROFILES_ACTIVE=dev

# Logging Level (optional)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_QUIMBAYAEVAL=DEBUG

# ============================================
# INSTRUCCIONES
# ============================================
# 1. Copiar este archivo como .env
# 2. Generar un JWT_SECRET seguro:
#
#    Windows PowerShell:
#    $bytes = New-Object byte[] 64
#    (New-Object Security.Cryptography.RNGCryptoServiceProvider).GetBytes($bytes)
#    [Convert]::ToBase64String($bytes)
#
#    Linux/Mac:
#    openssl rand -base64 64
#
# 3. Actualizar las credenciales de PostgreSQL
# 4. Agregar las URLs de tu frontend en CORS_ALLOWED_ORIGINS
